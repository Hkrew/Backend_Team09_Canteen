@model Canteen.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary mb-0"><i class="bi bi-receipt"></i> Chi tiết đơn hàng #@Model.Id</h2>
        <a asp-action="History" class="btn btn-outline-secondary fw-bold shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại lịch sử
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4 bg-light rounded-4">
            <div class="row">
                <div class="col-md-6 mb-3 mb-md-0">
                    <p class="mb-1 text-muted">Ngày đặt hàng:</p>
                    <h5 class="fw-bold text-dark">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</h5>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-1 text-muted">Trạng thái hiện tại:</p>

                    @if (Model.Status == 2)
                    {
                        <span class="badge bg-success fs-5 px-3 py-2 shadow-sm">Hoàn thành</span>
                    }
                    else if (Model.Status == 3)
                    {
                        <span class="badge bg-danger fs-5 px-3 py-2 shadow-sm">Đã hủy</span>
                    }
                    else if (Model.Status == 1)
                    {
                        <span class="badge bg-primary fs-5 px-3 py-2 shadow-sm">Đang chuẩn bị</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark fs-5 px-3 py-2 shadow-sm">Chờ xác nhận</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 text-start ps-4">Món ăn</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                            <th class="text-end pe-4">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            <tr>
                                <td class="text-start ps-4 fw-bold text-secondary fs-5">
                                    @if (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" style="height: 50px; width: 50px; object-fit: cover; border-radius: 8px;" class="me-3 shadow-sm" />
                                    }
                                    @item.Product?.Name
                                </td>

                                <td>@(item.Product != null ? item.Product.Price.ToString("N0") : "0") đ</td>

                                <td class="fw-bold">x @item.Quantity</td>

                                <td class="text-end pe-4 fw-bold text-danger">
                                    @(item.Product != null ? (item.Product.Price * item.Quantity).ToString("N0") : "0") đ
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold py-4 fs-5">Tổng cộng:</td>
                            <td class="text-end pe-4 fw-bold text-success fs-3 py-4">@Model.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>