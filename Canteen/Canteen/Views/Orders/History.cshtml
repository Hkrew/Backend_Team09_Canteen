@model IEnumerable<Canteen.Models.Order>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container mt-4 mb-5">
    <h2 class="fw-bold mb-4">Lịch sử đơn hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Bạn chưa có đơn hàng nào. <a asp-controller="Home" asp-action="Index">Đặt đồ ăn ngay!</a></div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.Id</td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                            <td>
                                @if (item.Status == 0)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Chờ xác nhận</span>
                                }
                                else if (item.Status == 1)
                                {
                                    <span class="badge bg-info text-dark"><i class="bi bi-fire"></i> Đang chuẩn bị</span>
                                }
                                else if (item.Status == 2)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã hoàn thành</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã hủy</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-bold">Xem chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>