@using Microsoft.AspNetCore.Identity
@using Canteen.Models
@inject SignInManager<AppUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Canteen</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Canteen.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom shadow-sm mb-4 py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-primary fs-3" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop me-1"></i>Canteen
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1 mt-2 mt-sm-0">

                        @if (!User.IsInRole("Admin") && !User.IsInRole("Staff"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold px-3 rounded-3" asp-area="" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart-check-fill text-primary fs-5 align-middle me-1"></i> Giỏ hàng
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold px-3 rounded-3" asp-area="" asp-controller="Orders" asp-action="History">
                                    <i class="bi bi-clock-history text-success fs-5 align-middle me-1"></i> Lịch sử đơn hàng
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold px-3 rounded-3" asp-area="Admin" asp-controller="Products" asp-action="Index">
                                    <i class="bi bi-cup-hot-fill text-danger fs-5 align-middle me-1"></i> Sản phẩm
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold px-3 rounded-3" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                                    <i class="bi bi-receipt text-warning fs-5 align-middle me-1"></i> Đơn hàng
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item border-start ms-2 ps-2 d-none d-lg-block"></li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold px-3 rounded-3" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                                    <i class="bi bi-tags-fill text-success fs-5 align-middle me-1"></i> Danh mục
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold px-3 rounded-3" asp-area="Admin" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-people-fill text-info fs-5 align-middle me-1"></i> Tài khoản
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav align-items-center gap-2 mt-2 mt-sm-0">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                @if (User.IsInRole("Customer"))
                                {
                                    <a class="nav-link text-dark fw-bold bg-light rounded-pill px-3 shadow-sm border" asp-area="" asp-controller="Profile" asp-action="Index" title="Sửa thông tin cá nhân">
                                        <i class="bi bi-person-circle text-primary me-1"></i> @User.Identity?.Name
                                    </a>
                                }
                                else
                                {
                                    <span class="nav-link text-dark fw-bold bg-light rounded-pill px-3 shadow-sm border pe-none">
                                        <i class="bi bi-person-badge-fill text-danger me-1"></i> @User.Identity?.Name
                                    </span>
                                }
                            </li>
                            <li class="nav-item ms-2">
                                <form class="form-inline m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                                    <button type="submit" class="btn btn-outline-danger fw-bold rounded-pill px-3">
                                        <i class="bi bi-box-arrow-right"></i>
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-secondary" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-auto py-3">
        <div class="container text-center fw-bold">
            &copy; 2026 - Canteen - Nơi thỏa mãn đam mê ẩm thực
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>