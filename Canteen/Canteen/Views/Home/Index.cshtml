@model IEnumerable<Canteen.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center mb-5 mt-4">
    <h1 class="display-4 fw-bold text-primary">Canteen GĐ-2</h1>
    <p class="lead text-muted">Nơi thỏa mãn đam mê ẩm thực của bạn!</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning text-center">Hiện tại Canteen chưa có món ăn nào.</div>
}
else
{
    // TUYỆT CHIÊU GROUP BY: Gom nhóm các món ăn theo Tên Danh Mục
    var groupedProducts = Model.GroupBy(p => p.Category != null ? p.Category.Name : "Chưa phân loại");

    foreach (var group in groupedProducts)
    {
        <div class="category-section mb-5">
            <h3 class="fw-bold text-danger border-bottom pb-2 mb-4 d-inline-block">
                @if (group.Key.ToLower().Contains("uống"))
                {
                    <i class="bi bi-cup-straw"></i>
                }
                else
                {
                    <i class="bi bi-egg-fried"></i>
                }
                @group.Key
            </h3>

            <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var item in group)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 rounded-3 text-center transition-hover">
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover; border-top-left-radius: 8px; border-top-right-radius: 8px;">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold text-dark mb-2">@item.Name</h5>

                                @if (item.IsAvailable)
                                {
                                    <span class="badge bg-success mx-auto mb-2"><i class="bi bi-check-circle"></i> Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger mx-auto mb-2"><i class="bi bi-x-circle"></i> Ngừng bán</span>
                                }

                                <p class="card-text text-danger fw-bold fs-5 mt-auto mb-3">@item.Price.ToString("N0") VNĐ</p>

                                @if (!User.IsInRole("Admin") && !User.IsInRole("Staff"))
                                {
                                    if (item.IsAvailable)
                                    {
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-auto">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold">Thêm vào giỏ</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary w-100 fw-bold mt-auto" disabled>Tạm hết hàng</button>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>