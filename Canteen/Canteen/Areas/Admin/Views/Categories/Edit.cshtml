@model Canteen.Models.Category
@{
    ViewData["Title"] = "Cập nhật Danh mục";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-6">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> Cập nhật Danh mục</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold">Tên danh mục</label>
                        <input asp-for="Name" class="form-control form-control-lg" required />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-bold flex-grow-1"><i class="bi bi-save"></i> Lưu thay đổi</button>
                        <a asp-action="Index" class="btn btn-secondary fw-bold">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>