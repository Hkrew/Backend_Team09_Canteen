@model Canteen.Models.AppUser
@{
    ViewData["Title"] = "Cập nhật Tài khoản";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0 fw-bold">Cập nhật tài khoản nhân viên</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input type="email" class="form-control bg-light" value="@Model.Email" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên</label>
                        <input type="text" name="fullName" class="form-control" value="@Model.FullName" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input type="text" name="phoneNumber" class="form-control" value="@Model.PhoneNumber" placeholder="Nhập số điện thoại..." />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success fw-bold flex-grow-1">Lưu thay đổi</button>
                        <a asp-action="Index" class="btn btn-secondary fw-bold">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>