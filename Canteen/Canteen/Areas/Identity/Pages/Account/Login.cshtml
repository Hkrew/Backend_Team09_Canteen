@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-primary text-white text-center py-4 rounded-top-4">
                <h3 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-right me-2"></i>Đăng Nhập</h3>
            </div>
            <div class="card-body p-5">
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3" role="alert"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope me-1"></i> Email của bạn</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control rounded-3" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="text-muted"><i class="bi bi-shield-lock me-1"></i> Mật khẩu</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label text-muted" asp-for="Input.RememberMe">Nhớ mật khẩu</label>
                        </div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none text-primary fw-bold small">Quên mật khẩu?</a>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-primary w-100 btn-lg fw-bold rounded-3 shadow-sm mb-4">
                        Đăng Nhập
                    </button>

                    <div class="text-center mt-2 border-top pt-4">
                        <span class="text-muted">Chưa có tài khoản?</span>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold text-success ms-1">Đăng ký ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}