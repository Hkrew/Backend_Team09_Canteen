@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 rounded-top-4">
                <h3 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Tạo tài khoản mới</h3>
            </div>
            <div class="card-body p-5">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="form-floating">
                                <input asp-for="Input.FullName" class="form-control rounded-3" aria-required="true" placeholder="Họ và tên" />
                                <label asp-for="Input.FullName" class="text-muted">Họ và tên</label>
                                <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="form-floating">
                                <input asp-for="Input.PhoneNumber" class="form-control rounded-3" aria-required="true" placeholder="Số điện thoại" />
                                <label asp-for="Input.PhoneNumber" class="text-muted">Số điện thoại</label>
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope me-1"></i> Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="text-muted"><i class="bi bi-shield-lock me-1"></i> Mật khẩu</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.ConfirmPassword" class="text-muted"><i class="bi bi-shield-check me-1"></i> Xác nhận mật khẩu</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-success w-100 btn-lg fw-bold rounded-3 shadow-sm mt-2 mb-4">
                        Đăng ký tài Khoản
                    </button>

                    <div class="text-center mt-2 border-top pt-4">
                        <span class="text-muted">Đã có tài khoản?</span>
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold text-primary ms-1">Đăng nhập tại đây</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}