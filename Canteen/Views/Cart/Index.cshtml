@model IEnumerable<Canteen.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2 class="fw-bold mb-4 mt-3">Giỏ hàng</h2>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <h5 class="text-muted">Giỏ hàng của bạn đang trống!</h5>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">Quay lại thực đơn</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr class="text-muted text-center">
                    <th class="text-start">Sản phẩm</th>
                    <th>Giá tiền</th>
                    <th>Số lượng</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="border-bottom text-center">
                        <td class="text-start py-3">
                            <div class="d-flex align-items-center">
                                <img src="@item.ImageUrl" class="rounded me-3 shadow-sm" style="width: 70px; height: 70px; object-fit: cover;" alt="@item.ProductName" />
                                <div>
                                    <h6 class="mb-1 fw-bold">@item.ProductName</h6>
                                </div>
                            </div>
                        </td>
                        <td>@item.Price.ToString("N0") VNĐ</td>
                        <td>
                            <div class="d-flex justify-content-center align-items-center">
                                <a asp-action="Decrease" asp-route-id="@item.ProductId" class="btn btn-sm btn-light border fw-bold px-3 fs-5">-</a>
                                <span class="mx-3 fw-bold fs-5 bg-secondary text-white px-3 py-1 rounded">@item.Quantity</span>
                                <a asp-action="Increase" asp-route-id="@item.ProductId" class="btn btn-sm btn-light border fw-bold px-3 fs-5">+</a>
                                <a asp-action="Remove" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-dark fw-bold ms-4 px-3">Xoá</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4 border-top pt-4 border-dark border-2">
        <h4 class="fw-bold mb-0">Tổng tiền : <span class="text-dark">@Model.Sum(x => x.Total).ToString("N0") VNĐ</span></h4>
        <a asp-controller="Cart" asp-action="Checkout" class="btn btn-info text-white fw-bold px-5 py-2 fs-5" style="border-radius: 30px;">Thanh Toán</a>
    </div>
}